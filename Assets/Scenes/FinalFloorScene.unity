  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 9517b26f6a0536449b849290b9725713, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  interactionPrompt: Press F to Read
  interactionRadius: 2
  documentTitle: SURVIVE
  documentText: "If anyone is reading this\u2026\r\nSomething is wrong with this
    school.\r\nThey\u2019re not people anymore.\r\nWe had to lock the doors to slow
    them down.\r\nEach floor is sealed with a code.\r\nIf you want to get out, you
    need to find the numbers.\r\nThey\u2019re hidden in the classrooms\u2026 written,
    scratched, or left behind.\r\nWe left clues wherever we could.\r\nPay attention
    to everything.\r\nStay quiet.\r\nHide if you need to. And whatever you do\u2026
    Don\u2019t let them see you."
